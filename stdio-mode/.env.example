# =======================================================================
#  SRE Capacity Agent — Environment Variables
#  Copy this file to .env and fill in your real values.
#  .env is gitignored — never commit it.
#
#  Usage:
#    Windows PowerShell:  Get-Content .env | ForEach { $env:$_ }
#    Windows CMD:         for /f "delims=" %i in (.env) do set %i
#    Linux / Mac:         export $(cat .env | xargs)
# =======================================================================


# ── GRAFANA / PROMETHEUS ────────────────────────────────────────────────
#
#  Base URL only — strip everything after the port.
#  CORRECT:  https://prod1-grafana.wellsfargo.net
#  WRONG:    https://prod1-grafana.wellsfargo.net/api/datasources/proxy/1/api/v1/...
#
GRAFANA_URL=https://prod1-grafana.wellsfargo.net

#  Service account token — create in Grafana → Administration → Service Accounts
#  Give it Viewer role. Token starts with glsa_
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#  Prometheus datasource UID in Grafana.
#  Short UIDs are valid — e.g. 'hyaV9HiVz' (not always a long UUID).
#  Get it from: python scripts/health_check.py  (prints all datasources)
GRAFANA_DS_UID=hyaV9HiVz

#  (OPTIONAL) Legacy numeric datasource ID — only used as fallback.
#  Leave as 1 unless auto-discovery fails and you know the exact ID.
GRAFANA_DATASOURCE_ID=1

#  Set to "true" ONLY if GRAFANA_URL points directly to a Prometheus server,
#  not a Grafana instance. Almost always false.
PROMETHEUS_DIRECT=false

#  Collector mode: "http" = direct REST  |  "grafana_mcp" = VS Code MCP server
PROM_MODE=http


# ── SPLUNK ──────────────────────────────────────────────────────────────
#
#  Base URL only — no path after port:8089.
#  CORRECT:  https://wf-lp.splunkcloud.com:8089
#  WRONG:    https://wf-lp.splunkcloud.com:8089/servicesNS/nobody/app/search/v2/...
#
SPLUNK_HOST=https://wf-lp.splunkcloud.com:8089

#  Bearer token — create in Splunk Web → Settings → Tokens
SPLUNK_TOKEN=eyJraWQiOiJzcGx1bmtfc2VjcmV0IiwiYWxnIjoiSFMyNTYifQ.xxxxxxxxxxxx

#  App ID that owns your search context — this is the Splunk app namespace
#  for your search. Find it in Splunk Web URL: /en-US/app/<APP_ID>/search
SPLUNK_APP=wf_ui_app_ctdlr

#  Splunk namespace owner. Almost always "nobody" (shared/global context).
#  Only change if your app requires a specific user namespace.
SPLUNK_OWNER=nobody

#  Collector mode: "http" = direct REST  |  "splunk_mcp" = VS Code MCP server
SPLUNK_MODE=http


# ── OCP / OPENSHIFT ─────────────────────────────────────────────────────
#
#  OCP API server URL — get it with: oc whoami --show-server
OCP_API_URL=https://api.your-cluster.example.com:6443

#  OCP Bearer token — get it with: oc whoami -t
#  For a service account: oc sa get-token <sa-name> -n <namespace>
OCP_TOKEN=sha256~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#  Default namespace to analyse
OCP_NAMESPACE=alprc-prod

#  Collector mode:
#    "ocp_mcp" = your server.py running in VS Code stdio (recommended)
#    "direct"  = hit OCP REST API directly with httpx (CLI testing)
OCP_MODE=ocp_mcp

#  Name key of your MCP server in .vscode/mcp.json → "servers": { "ocp-mcp": {...} }
OCP_MCP_SERVER=ocp-mcp

#  Set false for self-signed OCP TLS certs (common in enterprise clusters)
OCP_VERIFY_SSL=false


# ── LLM ─────────────────────────────────────────────────────────────────
#
#  Anthropic API key — only required for full LLM analysis and recommendations.
#  Without this, run with --dry-run to get prediction numbers only (no narrative).
#  Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
